              "name": "value",
              "ioValue": "__GEOMETRY_INPUT__"
            }
          ],
          "readMeText": "This is single point patch to cover the inflection point where the two circles meet. The Circles worked independently but when they were both trying to act on the same point it crashed",
          "global": true
        },
        {
          "atomType": "Readme",
          "x": 0.8042071197411004,
          "y": 0.13394919168591224,
